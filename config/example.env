# Copy this file to `.env` in the project root and fill in real values.
# The .env file is gitignored -- do not commit real secrets.

# --- OpenWeatherMap ---
# Sign up at https://openweathermap.org/api then go to API keys.
OWM_API_KEY=6503b68b145d951768d1c8af792634b4

# Set to "free" to use the /data/2.5/* endpoints (no card required),
# or "onecall" to use One Call API 3.0 (needs a paid subscription on file,
# even though the first 1000 calls/day are free).
OWM_MODE=free

# --- NWS API ---
# NWS requires no key but asks for a User-Agent identifying your app + contact.
NWS_USER_AGENT=GuardianAgent/0.1 (your_email@example.com)

# --- Twilio (free trial) ---
# From https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+15551234567

# --- Runtime ---
# Polling cadence for the main agent loop (in seconds).
POLL_INTERVAL_SECONDS=300

# Log level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO